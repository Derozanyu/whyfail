{
  "name": "whyfail-local",
  "version": "0.8.0",
  "description": "Evidence-driven command failure diagnostics for desktop, CLI, and local web UI.",
  "main": "desktop/main.js",
  "type": "module",
  "bin": {
    "whyfail": "./src/cli.js",
    "wf": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "desktop": "electron .",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder --win nsis portable",
    "test": "node --test",
    "demo": "node src/cli.js run --no-web -- node examples/failing-esm.mjs",
    "check-demo": "node src/cli.js check whyfail.example.yaml --no-web"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Derozanyu",
  "devDependencies": {
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.derozanyu.whyfail",
    "productName": "WhyFail",
    "asar": true,
    "files": [
      "desktop/**/*",
      "public/**/*",
      "src/**/*",
      "package.json",
      "LICENSE"
    ],
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhyFail",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ],
      "artifactName": "WhyFail-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "WhyFail-Portable-${version}-${arch}.${ext}"
    }
  },
  "license": "MIT",
  "allowScripts": {
    "electron": true,
    "electron-winstaller": true
  }
}
